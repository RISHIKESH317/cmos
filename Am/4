fs = 44100; % Sampling frequency
t = 0:1/fs:2; % Time vector (2 seconds)

% Generate Audio Signal (Sine Wave)
freq1 = 440; % Frequency of Audio Signal (Hz)
audioSignal = sin(2 * pi * freq1 * t); % Sine wave for audio

% Generate Music Signal (Square Wave)
freq2 = 880; % Frequency of Music Signal (Hz)
musicSignal = square(2 * pi * freq2 * t); % Square wave for music

% Normalize and Adjust Amplitudes of Signals
audioSignal = 0.6 * audioSignal; % Scale audio signal to 60% of max
amplitude
musicSignal = 0.6 * musicSignal; % Scale music signal to 60% of max
amplitude

% Mix Signals
mixedSignal = audioSignal + musicSignal; % Simple addition to mix
signals

% Normalize the mixed signal to avoid clipping
mixedSignal = mixedSignal / max(abs(mixedSignal)); % Normalize mixed
signal to [-1, 1]

% Play Mixed Signal
sound(mixedSignal, fs); % Play the mixed audio signal

% Plot Signals

2 | P a g e

figure;
subplot(3, 1, 1); % Plot the Audio Signal
plot(t, audioSignal);
title('Audio Signal');
xlabel('Time (seconds)');
ylabel('Amplitude');

subplot(3, 1, 2); % Plot the Music Signal
plot(t, musicSignal);
title('Music Signal');
xlabel('Time (seconds)');
ylabel('Amplitude');

subplot(3, 1, 3); % Plot the Mixed Signal
plot(t, mixedSignal);
title('Mixed Signal');
xlabel('Time (seconds)');
ylabel('Amplitude');
