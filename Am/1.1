Simulation of DSBSC modulator and demodulator using MATLAB 
clc; clear; close all; 
% Parameters  
Fs = 1e6;        
Fc = 10e3;       
Fm = 1e3;        
t = 0:1/Fs:1;    
% Sampling frequency (1 MHz) 
% Carrier frequency (10 kHz) 
% Message signal frequency (1 kHz) 
% Time vector (1 second duration) 
% Message Signal (Baseband signal) 
m_t = cos(2*pi*Fm*t); 
% Carrier Signal 
c_t = cos(2*pi*Fc*t); 
% DSB-SC Modulation 
modulated_signal = m_t .* c_t; 
% Demodulation (assuming perfect carrier recovery) 
demodulated_signal = modulated_signal .* c_t; 
% Low-pass filter to recover the original message signal 
[b, a] = butter(5, Fm/(Fs/2)); % Butterworth low-pass filter 
recovered_signal = filter(b, a, demodulated_signal); 
% Spectrum of Modulated Signal (FFT) 
nfft = 1024; 
modulated_spectrum = fftshift(abs(fft(modulated_signal, nfft))); 
f = (-nfft/2:nfft/2-1)*(Fs/nfft); % Frequency vector 
% Spectrum of Demodulated Signal (FFT) 
demodulated_spectrum = fftshift(abs(fft(demodulated_signal, nfft))); 
% Plot the signals 
1 | P a g e 
figure; 
subplot(3,1,1); 
plot(t, m_t, 'b', 'LineWidth', 1.5); 
title('Message Signal (Baseband)'); 
xlabel('Time (s)'); 
ylabel('Amplitude'); 
grid on; 
xlim([0 0.01]); % Limit x-axis for better visualization 
ylim([-1.5 1.5]); % Limit y-axis to match the message signal range 
legend('Message Signal'); 
subplot(3,1,2); 
plot(t, modulated_signal, 'r', 'LineWidth', 1.5); 
title('Modulated Signal (DSB-SC)'); 
xlabel('Time (s)'); 
ylabel('Amplitude'); 
grid on; 
xlim([0 0.01]); % Limit x-axis to focus on the signal period 
ylim([-1.5 1.5]); % Adjust y-axis based on signal amplitude 
legend('Modulated Signal'); 
subplot(3,1,3); 
plot(t, recovered_signal, 'k', 'LineWidth', 1.5); 
title('Recovered Signal (Demodulated)'); 
xlabel('Time (s)'); 
ylabel('Amplitude'); 
grid on; 
xlim([0 0.01]); % Limit x-axis to visualize demodulated signal clearly 
ylim([-1.5 1.5]); % Adjust y-axis for clarity 
legend('Recovered Signal'); 
% Plot the spectra 
figure; 
subplot(2,1,1); 
plot(f, modulated_spectrum, 'r', 'LineWidth', 1.5); 
