Program:
% SSB-SC Modulator and Demodulator with Enhanced Visualization for
Low-Frequency Time Domain
% Parameters
fs = 1e5; % Sampling frequency (Hz)
t = 0:1/fs:1; % Time vector (1 second duration)
fc = 1e4; % Carrier frequency (Hz)
f_m = 1e3; % Message signal frequency (Hz)
A_c = 1; % Carrier amplitude
A_m = 1; % Message amplitude
% Message signal (low-frequency signal)
m_t = A_m * cos(2*pi*f_m*t);
% Carrier signal
c_t = A_c * cos(2*pi*fc*t);
% SSB-SC Modulation (using Hilbert Transform for generating the
analytic signal)
analytic_signal = hilbert(m_t);
ssb_sc_signal = real(analytic_signal) .* cos(2*pi*fc*t);

% SSB-SC Demodulation (using the same carrier and low-pass filter)
demodulated_signal = ssb_sc_signal .* cos(2*pi*fc*t); % Multiply by
carrier
demodulated_signal = lowpass(demodulated_signal, f_m, fs); % Low-pass
filter to recover the message

% Plot message, modulated and demodulated signals with zoom on time
domain
figure;
subplot(3,1,1);
plot(t, m_t, 'LineWidth', 1.5);

2 | P a g e

title('Message Signal (Low-Frequency)', 'FontSize', 14);
xlabel('Time (s)', 'FontSize', 12);
ylabel('Amplitude', 'FontSize', 12);
xlim([0 0.05]); % Zoom in to see the low-frequency behavior better
grid on;

subplot(3,1,2);
plot(t, ssb_sc_signal, 'LineWidth', 1.5);
title('SSB-SC Modulated Signal', 'FontSize', 14);
xlabel('Time (s)', 'FontSize', 12);
ylabel('Amplitude', 'FontSize', 12);
xlim([0 0.05]); % Same zoom for modulated signal for comparison
grid on;

subplot(3,1,3);
plot(t, demodulated_signal, 'LineWidth', 1.5);
title('Demodulated Signal', 'FontSize', 14);
xlabel('Time (s)', 'FontSize', 12);
ylabel('Amplitude', 'FontSize', 12);
xlim([0 0.05]); % Same zoom for demodulated signal for comparison
grid on;

% Spectrum of the modulated and demodulated signals
figure;
subplot(2,1,1);
% Spectrum of the modulated signal
fft_mod = abs(fft(ssb_sc_signal));
f = fs*(0:(length(ssb_sc_signal)/2))/length(ssb_sc_signal);
plot(f, fft_mod(1:length(f)), 'LineWidth', 1.5);
title('Spectrum of SSB-SC Modulated Signal', 'FontSize', 14);
xlabel('Frequency (Hz)', 'FontSize', 12);
ylabel('Magnitude', 'FontSize', 12);
xlim([0 fc*2]); % Limit to a range around the carrier frequency
grid on;

3 | P a g e

subplot(2,1,2);
% Spectrum of the demodulated signal
fft_demod = abs(fft(demodulated_signal));
plot(f, fft_demod(1:length(f)), 'LineWidth', 1.5);
title('Spectrum of Demodulated Signal', 'FontSize', 14);
xlabel('Frequency (Hz)', 'FontSize', 12);
ylabel('Magnitude', 'FontSize', 12);
xlim([0 fc*2]); % Limit to a range around the carrier frequency
grid on;
